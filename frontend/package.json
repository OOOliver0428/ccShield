{
  "name": "reccshield-frontend",
  "version": "2.0.2",
  "private": true,
  "type": "module",
  "description": "Bilibili live-room moderator tool — frontend (Vue 3 + Vite + TypeScript)",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc --noEmit && vite build",
    "preview": "vite preview",
    "typecheck": "vue-tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint . --ext .vue,.ts,.tsx --max-warnings 0"
  },
  "dependencies": {
    "axios": "^1.7.7",
    "dayjs": "^1.11.13",
    "element-plus": "^2.8.8",
    "pinia": "^2.2.6",
    "qrcode": "^1.5.4",
    "vue": "^3.5.13"
  },
  "devDependencies": {
    "@hey-api/openapi-ts": "^0.99.0",
    "@types/node": "^22.10.1",
    "@types/qrcode": "^1.5.6",
    "@vitejs/plugin-vue": "^5.2.1",
    "@vue/test-utils": "^2.4.11",
    "@vue/tsconfig": "^0.7.0",
    "concurrently": "^10.0.3",
    "happy-dom": "^20.10.6",
    "jsdom": "^29.1.1",
    "msw": "^2.6.8",
    "typescript": "~5.6.3",
    "unplugin-auto-import": "^0.18.5",
    "unplugin-vue-components": "^0.27.4",
    "vite": "^5.4.11",
    "vitest": "^2.1.5",
    "vue-tsc": "^2.1.10"
  }
}
