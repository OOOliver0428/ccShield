# Python
__pycache__/
*.pyc
*.pyo
*.pyd
.venv/
venv/
.basedpyright/
.uv-cache/

# Test / coverage
.coverage
coverage.xml
htmlcov/
.pytest_cache/
pytest-results.xml

# Node
node_modules/
dist/

# Env / secrets — keep .env.example tracked, ignore everything else
.env
.env.*
!.env.example

# User-local quick room shortcuts (edit this file manually to remove entries)
config/quick_rooms.json

# Backend test fixtures (kept out of accidental commits but allow dir creation)
tests/fixtures/*.json

# Editor / OS
.vscode/
.idea/
.DS_Store
*.swp

# Codegraph runtime cache (symlink to ~/.omo/codegraph/...)
.codegraph

# Local Codex/pet validation artifacts and package-manager cache
.codex/
.codex-wangcai-*.json
.pnpm-store/

# .omo runtime/backup artifacts (planning docs tracked, runtime state not)
.omo/run-continuation/
.omo/drafts/*.bak
