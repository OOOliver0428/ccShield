# Python
__pycache__/
*.pyc
*.pyo
*.pyd
.venv/
venv/
.basedpyright/
.ruff_cache/
.mypy_cache/
.uv-cache/
*.egg-info/

# Test / coverage
.coverage
.coverage.*
coverage.xml
htmlcov/
.pytest_cache/
pytest-results.xml

# Node
node_modules/
dist/
/build/
/release-artifacts/

# Env / secrets — keep .env.example tracked, ignore everything else
.env
.env.*
!.env.example

# User-local quick room shortcuts (edit this file manually to remove entries)
config/quick_rooms.json

# Backend test fixtures (kept out of accidental commits but allow dir creation)
backend/tests/fixtures/*.json

# Runtime logs
*.log

# Editor / OS
.vscode/
.idea/
.DS_Store
Thumbs.db
Desktop.ini
*.swp

# Codegraph runtime cache (symlink to ~/.omo/codegraph/...)
.codegraph

# Local development-agent artifacts and package-manager cache
.agents/
.codex/
.codex-wangcai-*.json
.omo/
.pnpm-store/
